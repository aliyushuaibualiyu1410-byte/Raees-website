    font-weight: 700;
    padding: 2px 6px;
    border-radius: 10px;
}

/* Notifications Dropdown Window Framework */
.dropdown-alerts {
    position: absolute;
    top: 50px;
    right: 0;
    width: 320px;
    background: #1e293b;
    border: 1px solid var(--panel-border);
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.5);
    z-index: 110;
    padding: 16px;
    cursor: default;
}
.dropdown-alerts h4 { font-size: 0.95rem; margin-bottom: 12px; border-bottom: 1px solid var(--panel-border); padding-bottom: 8px; }
.dropdown-alerts ul { list-style: none; max-height: 240px; overflow-y: auto; }
.dropdown-alerts li { font-size: 0.82rem; padding: 8px 0; border-bottom: 1px dashed rgba(255,255,255,0.05); line-height: 1.4; color: #cbd5e1; }
.dropdown-alerts li:last-child { border: none; }

/* =========================================================================
   DASHBOARD CARDS MODULE (METRICS)
   ========================================================================= */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 24px;
    margin-bottom: 32px;
}

.stat-card {
    background: var(--panel-glass);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--panel-border);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: transform 0.2s ease;
}
.stat-card:hover { transform: translateY(-2px); }

.stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
}

.total-items .stat-icon { background: rgba(56, 189, 248, 0.15); color: var(--primary); }
.low-stock .stat-icon { background: rgba(245, 158, 11, 0.15); color: var(--warning); }
.expiring .stat-icon { background: rgba(168, 85, 247, 0.15); color: #c084fc; }
.expired .stat-icon { background: rgba(239, 68, 68, 0.15); color: var(--danger); }

.stat-info h3 { font-size: 0.88rem; color: var(--text-muted); font-weight: 500; }
.stat-info p { font-size: 1.75rem; font-weight: 700; margin-top: 4px; }

.dashboard-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
}

.dashboard-panel {
    background: var(--panel-glass);
    border: 1px solid var(--panel-border);
    border-radius: 12px;
    padding: 24px;
}
.dashboard-panel h3 { font-size: 1.1rem; margin-bottom: 20px; font-weight: 600; display: flex; align-items: center; gap: 8px; }

/* =========================================================================
   DATA TABLES ENGINE DESIGN
   ========================================================================= */
.action-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
}

.search-filter-group {
    display: flex;
    gap: 12px;
    flex-grow: 1;
    max-width: 600px;
}

.search-input-wrapper {
    position: relative;
    flex-grow: 1;
}
.search-input-wrapper i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--text-muted); }
.search-input-wrapper input { padding-left: 40px; }

.form-select { width: 180px; }

.table-container {
    background: var(--panel-glass);
    border: 1px solid var(--panel-border);
    border-radius: 12px;
    overflow-x: auto;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

.app-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.92rem;
}

.app-table th {
    background: rgba(15, 23, 42, 0.6);
    padding: 16px;
    font-weight: 600;
    color: var(--text-muted);
    border-bottom: 1px solid var(--panel-border);
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.5px;
}

.app-table td {
    padding: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    color: #e2e8f0;
    vertical-align: middle;
}

.app-table tbody tr:hover { background: rgba(255, 255, 255, 0.02); }

/* Operational Badges Rules */
.badge-status {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
}
.badge-status.normal { background: rgba(16, 185, 129, 0.15); color: #34d399; }
.badge-status.low { background: rgba(245, 158, 11, 0.15); color: #fbbf24; }
.badge-status.expiring { background: rgba(168, 85, 247, 0.15); color: #d8b4fe; }
.badge-status.expired { background: rgba(239, 68, 68, 0.15); color: #f87171; }

.table-actions { display: flex; gap: 8px; }
.btn-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    background: rgba(255,255,255,0.05);
    color: var(--text-main);
    transition: var(--transition-smooth);
}
.btn-icon:hover { background: rgba(255,255,255,0.15); }
.btn-icon.edit:hover { color: var(--primary); }
.btn-icon.delete:hover { color: var(--danger); }

/* Miniature Panel Adjustments */
.alert-table-wrapper { max-height: 350px; overflow-y: auto; }
.app-table.miniature th { padding: 10px 14px; }
.app-table.miniature td { padding: 10px 14px; font-size: 0.85rem; }

/* =========================================================================
   CHARTS & SOP MODULE VIEWS
   ========================================================================= */
.charts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 24px; }
.chart-card { background: var(--panel-glass); border: 1px solid var(--panel-border); border-radius: 12px; padding: 24px; }
.chart-card h4 { font-size: 1rem; margin-bottom: 20px; color: var(--text-muted); font-weight: 500; }
.chart-container { position: relative; height: 280px; width: 100%; display: flex; justify-content: center; }

.reports-header-actions { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }

.sop-document {
    background: #1e293b;
    border: 1px solid var(--panel-border);
    border-radius: 12px;
    padding: 40px;
    max-width: 800px;
    margin: 0 auto;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}
.sop-document h2 { font-size: 1.5rem; text-align: center; color: var(--primary); margin-bottom: 6px; }
.sop-meta { text-align: center; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 20px; }
.sop-document hr { border: 0; border-top: 1px solid var(--panel-border); margin-bottom: 24px; }
.sop-document h3 { font-size: 1.1rem; margin: 20px 0 10px 0; color: #e2e8f0; }
.sop-document p, .sop-document ul { font-size: 0.95rem; color: #cbd5e1; line-height: 1.6; margin-bottom: 14px; }
.sop-document ul { padding-left: 20px; }
.sop-document li { margin-bottom: 8px; }

/* =========================================================================
   MODAL DIALOG FRAMEWORKS
   ========================================================================= */
.modal-wrapper {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(4px);
    display: flex; justify-content: center; align-items: center;
    z-index: 200;
}

.modal-content {
    background: #1e293b;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    width: 100%; max-width: 650px;
    box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    overflow: hidden;
    animation: modalEntrance 0.25s ease-out;
}

@keyframes modalEntrance {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

.modal-header {
    background: rgba(15, 23, 42, 0.4);
    padding: 20px 24px;
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid var(--panel-border);
}
.modal-header h3 { font-size: 1.2rem; font-weight: 600; }
.close-btn { background: none; border: none; font-size: 1.8rem; color: var(--text-muted); cursor: pointer; }
.close-btn:hover { color: var(--text-main); }

#item-form { padding: 24px; }
.form-row { display: flex; gap: 16px; margin-bottom: 16px; }
.col-4 { flex: 0 0 calc(33.333% - 11px); }
.col-6 { flex: 0 0 calc(50% - 8px); }
.col-12 { flex: 0 0 100%; }

.modal-footer {
    display: flex; justify-content: flex-end; gap: 12px;
    margin-top: 24px; padding-top: 16px;
    border-top: 1px solid var(--panel-border);
}

/* =========================================================================
   RESPONSIVE DESIGN SYSTEM MEDIA QUERIES
   ========================================================================= */
@media (max-width: 992px) {
    .sidebar { width: 70px; }
    .sidebar-brand span, .menu-item span, .user-info div, #logout-btn span { display: none; }
    .main-content { margin-left: 70px; max-width: calc(100vw - 70px); padding: 20px; }
    .sidebar-brand { justify-content: center; padding: 20px 0; }
    .menu-item { justify-content: center; padding: 12px 0; }
    .user-info { justify-content: center; }
}

@media (max-width: 576px) {
    .form-row { flex-direction: column; gap: 16px; }
    .col-4, .col-6, .col-12 { flex: 0 0 100%; }
    .action-bar { flex-direction: column; align-items: stretch; }
    .search-filter-group { flex-direction: column; }
    .form-select { width: 100%; }
}

/* =========================================================================
   PRINT ENGINE OPTIMIZATION LAYOUTS
   ========================================================================= */
@media print {
    body { background: white !important; color: black !important; }
    .sidebar, .action-bar, .header-alerts, .table-actions, .modal-wrapper, #print-report-btn { display: none !important; }
    .main-content { margin-left: 0 !important; max-width: 100% !important; padding: 0 !important; }
    .app-view { display: block !important; }
    .app-table { border: 1px solid #000 !important; }
    .app-table th { background: #eee !important; color: #000 !important; }
    .app-table td { color: #000 !important; border-bottom: 1px solid #ccc !important; }
    .chart-card { page-break-inside: avoid; }
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LabStock Pro | Laboratory Inventory Management System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <div id="login-container" class="login-wrapper">
        <div class="login-card">
            <div class="login-header">
                <div class="login-logo">
                    <i class="fa-solid fa-flask-vial"></i>
                </div>
                <h2> 🔐LabStock Pro</h2>
                <p>Laboratory Inventory Management System</p>
            </div>
            <form id="login-form">
                <div class="form-group">
                    <label for="username"><i class="fa-solid fa-user"></i> Username</label>
                    <input type="text" id="username" autocomplete="username" placeholder="Enter admin username"
                        required>
                </div>
                <div class="form-group">
                    <label for="password"><i class="fa-solid fa-lock"></i> Password</label>
                    <input type="password" id="password" autocomplete="current-password" placeholder="Enter password"
                        required>
                </div>
                <div id="login-error" class="error-msg hidden">
                    <i class="fa-solid fa-circle-exclamation"></i> Invalid credentials. Please try again.
                </div>
                <button type="submit" class="btn btn-primary btn-block">
                    <span>Login</span> <i class="fa-solid fa-right-to-bracket"></i>
                </button>
            </form>
            <div class="login-footer">
                <p>&copy; 2026 LabStock Pro. All Rights Reserved.</p>
            </div>
        </div>
    </div>

    <div id="app-container" class="app-wrapper hidden">

        <aside class="sidebar">
            <div class="sidebar-brand">
                <i class="fa-solid fa-flask-vial"></i>
                <span>LabStock <span>Pro</span></span>
            </div>

            <nav class="sidebar-menu">
                <a href="#" class="menu-item active" data-target="dashboard-view">
                    <i class="fa-solid fa-chart-pie"></i> <span>Dashboard</span>
                </a>
                <a href="#" class="menu-item" data-target="inventory-view">
                    <i class="fa-solid fa-boxes-stacked"></i> <span>Inventory</span>
                </a>
                <a href="#" class="menu-item" data-target="reports-view">
                    <i class="fa-solid fa-chart-line"></i> <span>📈Analytics & Reports</span>
                </a>
                <a href="#" class="menu-item" data-target="sop-view">
                    <i class="fa-solid fa-book-bookmark"></i> <span> 📜 Standard SOP</span>
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="user-info">
                    <i class="fa-solid fa-circle-user"></i>
                    <div>
                        <p class="user-name">Admin User</p>
                        <p class="user-role">System Administrator</p>
                    </div>
                </div>
                <button id="logout-btn" class="btn btn-danger btn-block">
                    <i class="fa-solid fa-power-off"></i> <span>Logout</span>
                </button>
            </div>
        </aside>

        <main class="main-content">

            <header class="top-navbar">
                <div class="page-title">
                    <h1 id="current-view-title">Dashboard Overview</h1>
                    <p class="date-display" id="live-date">Monday, June 29, 2026</p>
                </div>
                <div class="header-alerts" id="global-alert-trigger">
                    <i class="fa-solid fa-bell"></i>
                    <span class="badge hidden" id="alert-badge">0</span>
                    <div class="dropdown-alerts hidden" id="dropdown-alerts-box">
                        <h4>System Notifications</h4>
                        <ul id="alert-notifications-list">
                        </ul>
                    </div>
                </div>
            </header>

            <section id="dashboard-view" class="app-view">
                <div class="stats-grid">
                    <div class="stat-card total-items">
                        <div class="stat-icon"><i class="fa-solid fa-cubes"></i></div>
                        <div class="stat-info">
                            <h3>Total Items</h3>
                            <p id="stat-total">0</p>
                        </div>
                    </div>
                    <div class="stat-card low-stock">
                        <div class="stat-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
                        <div class="stat-info">
                            <h3>Low Stock</h3>
                            <p id="stat-low">0</p>
                        </div>
                    </div>
                    <div class="stat-card expiring">
                        <div class="stat-icon"><i class="fa-solid fa-hourglass-half"></i></div>
                        <div class="stat-info">
                            <h3>Expiring Soon</h3>
                            <p id="stat-expiring">0</p>
                        </div>
                    </div>
                    <div class="stat-card expired">
                        <div class="stat-icon"><i class="fa-solid fa-skull-crossbones"></i></div>
                        <div class="stat-info">
                            <h3>Expired Items</h3>
                            <p id="stat-expired">0</p>
                        </div>
                    </div>
                </div>

                <div class="dashboard-layout">
                    <div class="dashboard-panel active-alerts">
                        <h3><i class="fa-solid fa-circle-exclamation text-danger"></i> Critical Item Statuses</h3>
                        <div class="alert-table-wrapper">
                            <table class="app-table miniature">
                                <thead>
                                    <tr>
                                        <th>Item Name</th>
                                        <th>Status</th>
                                        <th>Condition</th>
                                    </tr>
                                </thead>
                                <tbody id="dashboard-alerts-tbody">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </section>

            <section id="inventory-view" class="app-view hidden">
                <div class="action-bar">
                    <div class="search-filter-group">
                        <div class="search-input-wrapper">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <input type="text" id="search-inventory" placeholder="Search by name, CAS number, batch...">
                        </div>
                        <select id="filter-status" class="form-select">
                            <option value="all">All Statuses</option>
                            <option value="normal">Normal</option>
                            <option value="low">Low Stock</option>
                            <option value="expiring">Expiring Soon</option>
                            <option value="expired">Expired</option>
                        </select>
                    </div>
                    <div class="action-buttons">
                        <button id="open-add-modal-btn" class="btn btn-success">
                            <i class="fa-solid fa-plus"></i> Add New Item
                        </button>
                        <button id="export-csv-btn" class="btn btn-outline">
                               <button class="btn-green" onclick="exportExcel()">📊 Export Excel</button>
                            <button class="btn-yellow" onclick="exportCSV()">📄 Export CSV</button>
                        </button>
                    </div>
                </div>
                <div class="table-container">
                    <table class="app-table" id="inventory-table">
                        <thead>
                            <tr>
                                <th>Item ID</th>
                                <th>Name / Chemical</th>
                                <th>CAS Number</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Expiry Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="inventory-tbody">
                        </tbody>
                    </table>
                </div>
            </section>

            <section id="reports-view" class="app-view hidden">
                <div class="reports-header-actions">
                    <h3>Visual Inventory Breakdown</h3>
                    <button id="print-report-btn" class="btn btn-outline">
                        <i class="fa-solid fa-print"></i> Print Executive Report
                    </button>
                </div>
                <div class="charts-grid">
                    <div class="chart-card">
                        <h4>Stock Status Analysis</h4>
                        <div class="chart-container">
                            <canvas id="statusPieChart"></canvas>
                        </div>
                    </div>
                    <div class="chart-card">
                        <h4>Category Item Count</h4>
                        <div class="chart-container">
                            <canvas id="categoryBarChart"></canvas>
                        </div>
                    </div>
                </div>
            </section>

            <section id="sop-view" class="app-view hidden">
                <div class="sop-document">
                    <h2>LABORATORY INVENTORY STANDARD OPERATING PROCEDURE (SOP)</h2>
                    <p class="sop-meta">Document ID: SOP-LAB-INV-001 | Version 2.4 | Effective Date: June 2026</p>
                    <hr>

                    <h3>1. Purpose & Scope</h3>
                    <p>This document defines strict procedures for maintaining, counting, storing, and disposing of
                        laboratory reagents, samples, and equipment elements. Adherence ensures academic integrity,
                        quality safety standards, and operational precision.</p>

                    <h3>2. Inventory Logging Protocols</h3>
                    <ul>
                        <li>All incoming chemical compounds and biological agents must immediately be tracked down
                            within this system before floor staging.</li>
                        <li>Required fields include the exact Chemical Abstract Service (CAS) registered registry ID
                            where applicable.</li>
                        <li>Quantities must be updated immediately upon deduction or physical usage cycles within active
                            benches.</li>
                    </ul>

                    <h3>3. Threshold & Expiry Enforcement</h3>
                    <p>Items flagged under <strong>Low Stock</strong> (below minimum structural safety thresholds) must
                        immediately trigger standard acquisition procurement queues. Any materials crossing past
                        expiration metrics must immediately be pulled from primary cabinets and logged into historical
                        waste cycles to prevent workflow errors.</p>
                </div>
            </section>
        </main>
    </div>

    <div id="item-modal" class="modal-wrapper hidden">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="modal-title">Add New Laboratory Item</h3>
                <button id="close-modal-btn" class="close-btn">&times;</button>
            </div>
            <form id="item-form">
                <input type="hidden" id="edit-item-id">

                <div class="form-row">
                    <div class="form-group col-6">
                        <label for="item-name">Item / Chemical Name*</label>
                        <input type="text" id="item-name" placeholder="e.g., Sodium Chloride" required>
                    </div>
                    <div class="form-group col-6">
                        <label for="item-cas">CAS Number / Code</label>
                        <input type="text" id="item-cas" placeholder="e.g., 7647-14-5">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-6">
                        <label for="item-category">Category*</label>
                        <select id="item-category" required>
                            <option value="">Select Category</option>
                            <option value="Reagents">Reagents</option>
                            <option value="Glassware">Glassware</option>
                            <option value="Equipments">Equipments</option>
                            <option value="Safety Gear">Safety Gear</option>
                            <option value="Consumables">Consumables</option>
                        </select>
                    </div>
                    <div class="form-group col-6">
                        <label for="item-location">Storage Location*</label>
                        <input type="text" id="item-location" placeholder="e.g., Cabinet B, Shelf 3" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-4">
                        <label for="item-qty">Current Quantity*</label>
                        <input type="number" id="item-qty" min="0" placeholder="0" required>
                    </div>
                    <div class="form-group col-4">
                        <label for="item-min-qty">Min Threshold*</label>
                        <input type="number" id="item-min-qty" min="0" placeholder="Low stock indicator limit" required>
                    </div>
                    <div class="form-group col-4">
                        <label for="item-unit">Unit*</label>
                        <input type="text" id="item-unit" placeholder="e.g., ml, g, units" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group col-12">
                        <label for="item-expiry">Expiration Date*</label>
                        <input type="date" id="item-expiry" required>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" id="cancel-modal-btn" class="btn btn-outline">Cancel</button>
                    <button type="submit" id="save-item-btn" class="btn btn-primary">Save Item</button>
                </div>
            </form>
        </div>
    </div>

    <script src="script.js"></script>
</body>

</html>
